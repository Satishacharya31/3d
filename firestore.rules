rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint: User
    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.uid == request.auth.uid
        && data.uid == userId
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation Blueprint: Conversation
    function isValidConversation(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation Blueprint: Message
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'conversationId', 'ownerId', 'role', 'text', 'image', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.conversationId is string && data.conversationId.size() <= 128
        && data.ownerId == request.auth.uid
        && (data.role == 'user' || data.role == 'model')
        && (data.text == null || (data.text is string && data.text.size() <= 1048576))
        && (data.image == null || (data.image is string && data.image.size() <= 4194304))
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isEmailVerified() && request.auth.uid == userId;
      allow create: if isEmailVerified()
        && isValidId(userId)
        && isValidUser(incoming(), userId)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isEmailVerified()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming(), userId)
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt']);

      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;

      allow create: if isEmailVerified()
        && isValidId(conversationId)
        && isValidConversation(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isEmailVerified()
        && isValidId(conversationId)
        && existing().ownerId == request.auth.uid
        && isValidConversation(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);

      allow delete: if isEmailVerified()
        && isValidId(conversationId)
        && existing().ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow get: if isEmailVerified() && existing().ownerId == request.auth.uid;
        allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;

        allow create: if isEmailVerified()
          && isValidId(messageId)
          && isValidId(conversationId)
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.ownerId == request.auth.uid
          && isValidMessage(incoming())
          && incoming().conversationId == conversationId
          && incoming().createdAt == request.time;

        allow update, delete: if false;
      }
    }
  }
}
